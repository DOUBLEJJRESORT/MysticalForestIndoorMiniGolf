<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Mystical Forest Indoor Glow Mini-Golf | Mobile Scorecard</title>
  <style>
    :root {
      --bg:#060913;
      --panel:rgba(12,16,28,.92);
      --panel-2:rgba(16,20,36,.96);
      --line:rgba(255,255,255,.10);
      --text:#f4fbff;
      --muted:#bfd0db;
      --green:#63ffb4;
      --blue:#5de2ff;
      --purple:#b56dff;
      --pink:#ff7ad8;
      --gold:#ffe38f;
      --danger:#ff9aad;
      --shadow:0 10px 30px rgba(0,0,0,.35), 0 0 35px rgba(93,226,255,.12);
      --radius:22px;
    }
    * { box-sizing:border-box; }
    html, body {
      margin:0; padding:0;
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at 20% 10%, rgba(99,255,180,.12), transparent 24%),
        radial-gradient(circle at 90% 15%, rgba(181,109,255,.12), transparent 22%),
        radial-gradient(circle at 50% 100%, rgba(93,226,255,.10), transparent 28%),
        linear-gradient(180deg, #04070e 0%, #080d18 55%, #050812 100%);
      color:var(--text);
      min-height:100vh;
      overflow-x:hidden;
    }
    .stars::before, .stars::after {
      content:"";
      position:fixed; inset:0;
      pointer-events:none;
      background-image:
        radial-gradient(circle, rgba(255,255,255,.7) 0 1px, transparent 1.7px),
        radial-gradient(circle, rgba(99,255,180,.55) 0 1px, transparent 1.8px),
        radial-gradient(circle, rgba(181,109,255,.5) 0 1px, transparent 1.8px);
      background-size:160px 160px, 220px 220px, 260px 260px;
      background-position:0 0, 50px 80px, 120px 20px;
      opacity:.24;
      animation: drift 38s linear infinite;
    }
    .stars::after { opacity:.12; transform:scale(1.18); animation-duration:58s; }
    @keyframes drift { from { transform:translateY(0); } to { transform:translateY(-110px); } }

    .app {
      max-width:520px;
      margin:0 auto;
      min-height:100vh;
      padding:16px 14px 28px;
      position:relative;
      z-index:1;
    }
    .card {
      background:linear-gradient(180deg, rgba(14,18,32,.94), rgba(10,14,26,.98));
      border:1px solid var(--line);
      border-radius:28px;
      box-shadow:var(--shadow);
      padding:18px;
      margin-bottom:14px;
      backdrop-filter: blur(14px);
    }
    .page { display:none; }
    .page.active { display:block; animation:fadeIn .24s ease; }
    @keyframes fadeIn { from { opacity:.4; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }

    .top-logo {
      width:112px; height:112px; object-fit:contain;
      display:block; margin:4px auto 14px;
      filter: drop-shadow(0 0 14px rgba(255,255,255,.08));
      border-radius:50%;
    }
    .eyebrow {
      display:inline-block;
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.08);
      color:var(--gold);
      border-radius:999px;
      padding:8px 12px;
      font-size:.78rem;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
      margin-bottom:12px;
    }
    h1 {
      margin:0;
      text-align:center;
      line-height:.98;
      font-size:clamp(2rem, 8vw, 3rem);
      font-weight:900;
      letter-spacing:.02em;
      text-shadow:0 0 18px rgba(93,226,255,.14);
    }
    .glow {
      display:block;
      background:linear-gradient(90deg, var(--green), var(--blue), var(--purple), var(--pink));
      -webkit-background-clip:text;
      background-clip:text;
      color:transparent;
    }
    h2 {
      margin:0 0 6px;
      font-size:1.2rem;
      font-weight:800;
    }
    .sub, .meta, .small {
      color:var(--muted);
      line-height:1.55;
    }
    .sub {
      text-align:center;
      font-size:1rem;
      margin:14px auto 18px;
      max-width:380px;
    }
    .small { font-size:.86rem; }
    .progress {
      display:flex;
      gap:8px;
      margin:8px 0 18px;
    }
    .progress span {
      flex:1;
      height:8px;
      border-radius:999px;
      background:rgba(255,255,255,.08);
      overflow:hidden;
      position:relative;
    }
    .progress span.active::after {
      content:"";
      position:absolute; inset:0;
      background:linear-gradient(90deg, var(--green), var(--blue));
      box-shadow:0 0 18px rgba(93,226,255,.32);
    }
    .btn-row {
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-top:14px;
    }
    button {
      appearance:none;
      border:none;
      border-radius:18px;
      font-weight:800;
      letter-spacing:.01em;
      cursor:pointer;
      transition:.2s ease;
      -webkit-tap-highlight-color: transparent;
      min-height:52px;
      font-size:1rem;
      padding:14px 16px;
    }
    button:active { transform:scale(.985); }
    .btn-primary {
      flex:1 1 180px;
      color:#04120b;
      background:linear-gradient(90deg, var(--green), var(--blue));
      box-shadow:0 0 0 1px rgba(255,255,255,.08) inset, 0 0 26px rgba(93,226,255,.18);
    }
    .btn-secondary {
      flex:1 1 140px;
      color:var(--text);
      background:rgba(255,255,255,.07);
      border:1px solid rgba(255,255,255,.10);
    }
    .btn-danger {
      color:#fff4f6;
      background:rgba(255,154,173,.16);
      border:1px solid rgba(255,154,173,.24);
    }
    .field {
      margin-top:14px;
    }
    label {
      display:block;
      font-size:.9rem;
      font-weight:700;
      color:var(--muted);
      margin-bottom:7px;
    }
    input[type="text"], input[type="number"] {
      width:100%;
      border-radius:16px;
      border:1px solid rgba(255,255,255,.10);
      background:rgba(255,255,255,.05);
      color:var(--text);
      padding:14px 14px;
      font-size:1rem;
      outline:none;
    }
    input:focus {
      border-color:rgba(99,255,180,.5);
      box-shadow:0 0 0 3px rgba(99,255,180,.12);
    }
    .inline {
      display:grid;
      grid-template-columns:110px 1fr;
      gap:10px;
      align-items:end;
    }
    .players-list {
      display:grid;
      gap:10px;
      margin-top:12px;
    }
    .chip {
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.08);
      color:var(--muted);
      font-size:.84rem;
      font-weight:700;
    }
    .chip-wrap {
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      margin-top:8px;
    }
    .tabs {
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:8px;
      margin-bottom:12px;
    }
    .tab-btn.active {
      color:#04120b;
      background:linear-gradient(90deg, var(--green), var(--blue));
      border:none;
    }
    .holes-panel { display:none; }
    .holes-panel.active { display:block; }

    .hole-card {
      display:grid;
      grid-template-columns:64px 1fr;
      gap:12px;
      align-items:start;
      padding:12px;
      border-radius:20px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.08);
      margin-bottom:10px;
    }
    .hole-badge {
      width:64px; height:64px;
      border-radius:18px;
      display:grid; place-items:center;
      font-weight:900;
      font-size:1.1rem;
      color:#04120b;
      background:linear-gradient(135deg, var(--green), var(--blue));
      box-shadow:0 0 18px rgba(93,226,255,.16);
    }
    .score-grid {
      display:grid;
      grid-template-columns:1fr 84px;
      gap:8px;
      align-items:center;
      margin-bottom:8px;
    }
    .score-name {
      font-weight:700;
      font-size:.98rem;
    }
    .score-grid input {
      text-align:center;
      padding:12px 8px;
      font-weight:800;
    }
    .totals {
      display:grid;
      gap:10px;
      margin-top:12px;
    }
    .total-item {
      display:grid;
      grid-template-columns:auto 1fr auto;
      align-items:center;
      gap:12px;
      padding:12px 14px;
      border-radius:18px;
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.08);
    }
    .rank {
      width:34px; height:34px;
      border-radius:50%;
      display:grid; place-items:center;
      background:linear-gradient(90deg, var(--gold), #fff3bf);
      color:#071017;
      font-weight:900;
      font-size:.92rem;
    }
    .score-pill {
      min-width:54px;
      text-align:center;
      padding:8px 10px;
      border-radius:999px;
      background:rgba(93,226,255,.12);
      border:1px solid rgba(93,226,255,.18);
      font-weight:900;
    }
    .notice {
      margin-top:12px;
      padding:12px 14px;
      border-radius:18px;
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.08);
    }
  </style>
</head>
<body>
  <div class="stars"></div>

  <div class="app">
    <div id="pageWelcome" class="page active">
      <div class="card">
        <img src="data:image/png;base64," alt="Double JJ Resort Logo" class="top-logo">
        <div style="text-align:center;">
          <div class="eyebrow">Double JJ Resort</div>
        </div>
        <h1>Mystical Forest <span class="glow">Indoor Glow Mini-Golf</span></h1>
        <p class="sub">Scan, start, and keep score right on your phone. Enter your group, track all 18 holes, and see who wins.</p>
        <div class="chip-wrap" style="justify-content:center;">
          <div class="chip">Phone friendly</div>
          <div class="chip">18 holes</div>
          <div class="chip">Monthly leaderboard</div>
        </div>
        <div class="btn-row">
          <button type="button" class="btn-primary" id="startRoundBtn">✨ Start Scorecard</button>
          <button type="button" class="btn-secondary" id="openLeaderboardBtn">🏆 Leaderboard</button>
        </div>
      </div>
    </div>

    <div id="pageSetup" class="page">
      <div class="card">
        <div class="progress"><span class="active"></span><span></span><span></span></div>
        <h2>Start Your Round</h2>
        <div class="meta">Pick how many players are in your group, then add names.</div>

        <div class="field inline">
          <div>
            <label for="playerCount">Players</label>
            <input id="playerCount" type="number" min="1" max="8" value="4">
          </div>
          <button type="button" class="btn-secondary" id="updatePlayersBtn">Update Names</button>
        </div>

        <div id="playersList" class="players-list"></div>

        <div class="btn-row">
          <button type="button" class="btn-secondary" id="backToWelcomeBtn">← Back</button>
          <button type="button" class="btn-primary" id="goToScorecardBtn">Continue to Scorecard</button>
        </div>
      </div>
    </div>

    <div id="pageScorecard" class="page">
      <div class="card">
        <div class="progress"><span class="active"></span><span class="active"></span><span></span></div>
        <h2>Your Scorecard</h2>
        <div class="meta">Enter each player’s score for every hole. Lowest total wins.</div>

        <div class="tabs">
          <button type="button" class="btn-secondary tab-btn active" data-tab="frontNine">Holes 1–9</button>
          <button type="button" class="btn-secondary tab-btn" data-tab="backNine">Holes 10–18</button>
        </div>

        <div id="frontNine" class="holes-panel active"></div>
        <div id="backNine" class="holes-panel"></div>

        <div class="notice">
          <div style="font-weight:800; margin-bottom:6px;">Live Totals</div>
          <div id="liveTotals" class="totals"></div>
        </div>

        <div class="btn-row">
          <button type="button" class="btn-secondary" id="backToSetupBtn">← Players</button>
          <button type="button" class="btn-secondary" id="resetRoundBtn">Reset Round</button>
          <button type="button" class="btn-primary" id="finishRoundBtn">Save Round</button>
        </div>
      </div>
    </div>

    <div id="pageLeaderboard" class="page">
      <div class="card">
        <div class="progress"><span class="active"></span><span class="active"></span><span class="active"></span></div>
        <h2>Monthly Leaderboard</h2>
        <div class="meta">This leaderboard resets automatically at the start of each new month on this hosted page.</div>

        <div class="notice" style="margin-top:12px;">
          <div style="font-weight:800;">Important</div>
          <div class="small" style="margin-top:6px;">
            This version gives you a monthly leaderboard stored in the browser. For a true public leaderboard shared by every guest on every phone, you would need a small database setup.
          </div>
        </div>

        <div style="margin-top:14px;">
          <div style="font-weight:800; margin-bottom:10px;">This Month</div>
          <div id="monthlyLeaderboard" class="totals"></div>
        </div>

        <div class="btn-row">
          <button type="button" class="btn-secondary" id="playAgainBtn">Start New Round</button>
          <button type="button" class="btn-danger" id="clearLeaderboardBtn">Clear Leaderboard</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const STORAGE = {
      players: "mysticalForest_mobile_players",
      scores: "mysticalForest_mobile_scores",
      leaderboard: "mysticalForest_mobile_leaderboard"
    };

    const PAGES = ["pageWelcome", "pageSetup", "pageScorecard", "pageLeaderboard"];
    let players = [];
    let scores = [];
    let leaderboard = JSON.parse(localStorage.getItem(STORAGE.leaderboard) || "[]");

    function currentMonthKey() {
      const now = new Date();
      return `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2, "0")}`;
    }

    function cleanupLeaderboard() {
      const month = currentMonthKey();
      leaderboard = leaderboard.filter(entry => entry.month === month);
      localStorage.setItem(STORAGE.leaderboard, JSON.stringify(leaderboard));
    }

    function showPage(id) {
      PAGES.forEach(pageId => {
        const el = document.getElementById(pageId);
        if (el) el.classList.toggle("active", pageId === id);
      });
      window.scrollTo({ top: 0, behavior: "smooth" });
      if (id === "pageLeaderboard") renderMonthlyLeaderboard();
    }

    function clampPlayers(value) {
      const count = parseInt(value || "4", 10);
      return Math.max(1, Math.min(8, isNaN(count) ? 4 : count));
    }

    function blankScores(count) {
      return Array.from({ length: 18 }, () => Array(count).fill(""));
    }

    function safeName(name, index) {
      const cleaned = (name || "").trim();
      return cleaned || `Player ${index + 1}`;
    }

    function renderPlayerFields(count) {
      const wrap = document.getElementById("playersList");
      const savedPlayers = JSON.parse(localStorage.getItem(STORAGE.players) || "[]");
      wrap.innerHTML = "";
      for (let i = 0; i < count; i++) {
        const field = document.createElement("div");
        field.className = "field";
        field.innerHTML = `
          <label for="player_${i}">Player ${i + 1}</label>
          <input type="text" id="player_${i}" maxlength="20" placeholder="Player ${i + 1}" value="${(savedPlayers[i] || "").replace(/"/g, "&quot;")}">
        `;
        wrap.appendChild(field);
      }
    }

    function readPlayers() {
      const count = clampPlayers(document.getElementById("playerCount").value);
      document.getElementById("playerCount").value = count;
      players = Array.from({ length: count }, (_, index) => safeName(document.getElementById(`player_${index}`)?.value, index));
      localStorage.setItem(STORAGE.players, JSON.stringify(players));
    }

    function loadScoresForPlayers() {
      const saved = JSON.parse(localStorage.getItem(STORAGE.scores) || "[]");
      if (
        Array.isArray(saved) &&
        saved.length === 18 &&
        saved.every(row => Array.isArray(row)) &&
        saved[0] &&
        saved[0].length === players.length
      ) {
        scores = saved;
      } else {
        scores = blankScores(players.length);
      }
      localStorage.setItem(STORAGE.scores, JSON.stringify(scores));
    }

    function saveScores() {
      localStorage.setItem(STORAGE.scores, JSON.stringify(scores));
    }

    function totals() {
      return players.map((_, playerIndex) =>
        scores.reduce((sum, row) => sum + (Number(row[playerIndex]) || 0), 0)
      );
    }

    function rankingFromTotals() {
      const sums = totals();
      return players
        .map((name, index) => {
          const holesPlayed = scores.reduce((count, row) => count + ((row[index] !== "" && row[index] != null) ? 1 : 0), 0);
          return {
            name,
            total: sums[index] || 0,
            holesPlayed
          };
        })
        .sort((a, b) => a.total - b.total || b.holesPlayed - a.holesPlayed || a.name.localeCompare(b.name));
    }

    function renderLiveTotals() {
      const live = document.getElementById("liveTotals");
      const ranking = rankingFromTotals();
      live.innerHTML = ranking.map((entry, index) => `
        <div class="total-item">
          <div class="rank">${index + 1}</div>
          <div>
            <div style="font-weight:800;">${entry.name}</div>
            <div class="small">${entry.holesPlayed}/18 holes entered</div>
          </div>
          <div class="score-pill">${entry.total}</div>
        </div>
      `).join("");
    }

    function renderHoleGroup(containerId, startHole, endHole) {
      const container = document.getElementById(containerId);
      let html = "";
      for (let hole = startHole; hole <= endHole; hole++) {
        html += `<div class="hole-card">
          <div class="hole-badge">${hole + 1}</div>
          <div>`;
        players.forEach((playerName, playerIndex) => {
          const value = scores[hole][playerIndex] ?? "";
          html += `
            <div class="score-grid">
              <div class="score-name">${playerName}</div>
              <input
                type="number"
                inputmode="numeric"
                min="0"
                max="20"
                data-hole="${hole}"
                data-player="${playerIndex}"
                value="${value}"
                placeholder="0"
              >
            </div>
          `;
        });
        html += `</div></div>`;
      }
      container.innerHTML = html;

      container.querySelectorAll("input").forEach(input => {
        input.addEventListener("input", event => {
          const hole = Number(event.target.dataset.hole);
          const player = Number(event.target.dataset.player);
          const raw = event.target.value;
          if (raw === "") {
            scores[hole][player] = "";
          } else {
            scores[hole][player] = Math.max(0, Math.min(20, parseInt(raw, 10) || 0));
          }
          saveScores();
          renderLiveTotals();
        });
      });
    }

    function renderScorecard() {
      renderHoleGroup("frontNine", 0, 8);
      renderHoleGroup("backNine", 9, 17);
      renderLiveTotals();
    }

    function renderMonthlyLeaderboard() {
      cleanupLeaderboard();
      const target = document.getElementById("monthlyLeaderboard");
      if (!leaderboard.length) {
        target.innerHTML = `<div class="small">No saved scores yet this month.</div>`;
        return;
      }
      const sorted = [...leaderboard]
        .sort((a, b) => a.total - b.total || new Date(b.date) - new Date(a.date))
        .slice(0, 20);

      target.innerHTML = sorted.map((entry, index) => `
        <div class="total-item">
          <div class="rank">${index + 1}</div>
          <div>
            <div style="font-weight:800;">${entry.name}</div>
            <div class="small">${entry.dateLabel}</div>
          </div>
          <div class="score-pill">${entry.total}</div>
        </div>
      `).join("");
    }

    function startRoundFlow() {
      showPage("pageSetup");
    }

    function continueToScorecard() {
      readPlayers();
      loadScoresForPlayers();
      renderScorecard();
      showPage("pageScorecard");
    }

    function saveRoundToLeaderboard() {
      if (!players.length) return;
      cleanupLeaderboard();
      const month = currentMonthKey();
      const date = new Date();
      const sums = totals();
      const entries = players.map((name, index) => ({
        name,
        total: sums[index] || 0,
        month,
        date: date.toISOString(),
        dateLabel: date.toLocaleDateString()
      }));

      leaderboard = [...leaderboard, ...entries]
        .sort((a, b) => a.total - b.total || new Date(b.date) - new Date(a.date))
        .slice(0, 100);

      localStorage.setItem(STORAGE.leaderboard, JSON.stringify(leaderboard));
      showPage("pageLeaderboard");
    }

    function resetRound() {
      if (!players.length) return;
      if (!confirm("Reset this round?")) return;
      scores = blankScores(players.length);
      saveScores();
      renderScorecard();
    }

    function clearLeaderboard() {
      if (!confirm("Clear the monthly leaderboard?")) return;
      leaderboard = [];
      localStorage.removeItem(STORAGE.leaderboard);
      renderMonthlyLeaderboard();
    }

    function setupTabs() {
      document.querySelectorAll(".tab-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          const tab = btn.dataset.tab;
          document.querySelectorAll(".tab-btn").forEach(item => item.classList.remove("active"));
          btn.classList.add("active");
          document.querySelectorAll(".holes-panel").forEach(panel => panel.classList.remove("active"));
          document.getElementById(tab).classList.add("active");
        });
      });
    }

    document.addEventListener("DOMContentLoaded", () => {
      cleanupLeaderboard();

      const savedPlayers = JSON.parse(localStorage.getItem(STORAGE.players) || "[]");
      const count = savedPlayers.length ? clampPlayers(savedPlayers.length) : 4;
      document.getElementById("playerCount").value = count;
      renderPlayerFields(count);

      document.getElementById("startRoundBtn").addEventListener("click", startRoundFlow);
      document.getElementById("openLeaderboardBtn").addEventListener("click", () => showPage("pageLeaderboard"));
      document.getElementById("backToWelcomeBtn").addEventListener("click", () => showPage("pageWelcome"));
      document.getElementById("backToSetupBtn").addEventListener("click", () => showPage("pageSetup"));
      document.getElementById("playAgainBtn").addEventListener("click", () => showPage("pageSetup"));
      document.getElementById("updatePlayersBtn").addEventListener("click", () => {
        const count = clampPlayers(document.getElementById("playerCount").value);
        document.getElementById("playerCount").value = count;
        renderPlayerFields(count);
      });
      document.getElementById("goToScorecardBtn").addEventListener("click", continueToScorecard);
      document.getElementById("finishRoundBtn").addEventListener("click", saveRoundToLeaderboard);
      document.getElementById("resetRoundBtn").addEventListener("click", resetRound);
      document.getElementById("clearLeaderboardBtn").addEventListener("click", clearLeaderboard);

      setupTabs();
      renderMonthlyLeaderboard();
    });
  </script>
</body>
</html>
